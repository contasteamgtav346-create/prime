    "helmet": "^8.1.0",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "tsx": "^4.20.3",
    "zustand": "^5.0.3",
    "zod": "^4.1.5",
    "express": "^4.21.2"
